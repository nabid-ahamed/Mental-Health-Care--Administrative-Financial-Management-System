@{
    ViewData["Title"] = "Hire Staff / Doctor";
}

<div class="container mt-4">
    <h2>🤝 Hire New Employee</h2>
    <p class="text-muted">Create accounts for Doctors, Staff, or other Admins.</p>
    <hr />

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger">@ViewBag.Error</div>
    }

    <form asp-action="Create" method="post" class="col-md-6">
        <div class="mb-3">
            <label class="form-label">Full Name</label>
            <input type="text" name="fullName" class="form-control" required placeholder="e.g. Dr. Gregory House" />
        </div>

        <div class="mb-3">
            <label class="form-label">Email (Username)</label>
            <input type="email" name="email" class="form-control" required />
        </div>

        <div class="mb-3">
            <label class="form-label">Temporary Password</label>
            <input type="text" name="password" class="form-control" required value="Hospital123!" />
            <small class="text-muted">User can change this later.</small>
        </div>

        <div class="mb-3">
            <label class="form-label">Role</label>
            <select id="roleSelect" name="role" class="form-select" required onchange="toggleSpecialization()">
                <option value="Staff">Staff</option>
                <option value="Doctor">Doctor</option>
                <option value="Admin">Admin</option>
            </select>
        </div>

        <div id="doctorFields" style="display:none;" class="p-3 mb-3 bg-light border rounded">
            <h5 class="text-primary">🩺 Doctor Details</h5>

            <div class="mb-3">
                <label class="form-label">Specialization</label>
                <input type="text" name="specialization" class="form-control" placeholder="e.g. Psychiatrist" />
            </div>

            <div class="mb-3">
                <label class="form-label">Consultation Fee (Tk.)</label>
                <input type="number" name="consultationFee" class="form-control" placeholder="e.g. 1500" value="0" />
                <small class="text-muted">This will be used for auto-billing.</small>
            </div>
        </div>

        <button type="submit" class="btn btn-success">Create Account</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </form>
</div>

<script>
    function toggleSpecialization() {
        var role = document.getElementById("roleSelect").value;
        var div = document.getElementById("doctorFields");

        // Show only if Doctor is selected
        if (role === "Doctor") {
            div.style.display = "block";
        } else {
            div.style.display = "none";
        }
    }
</script>