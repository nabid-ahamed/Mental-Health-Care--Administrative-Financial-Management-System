@model IEnumerable<MHC_AFMS.Controllers.UserViewModel>

@{
    ViewData["Title"] = "System Users";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center">
        <h2>👥 Employee Management</h2>
        <a asp-action="Create" class="btn btn-primary">+ Hire New Employee</a>
    </div>
    <hr />

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <table class="table table-hover table-bordered">
        <thead class="table-dark">
            <tr>
                <th>Name</th>
                <th>Email</th>
                <th>Role</th>
                <th>Specialization</th>
                <th style="width: 300px;">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model)
            {
                <tr>
                    <td class="align-middle">@user.FullName</td>
                    <td class="align-middle">@user.Email</td>
                    <td class="align-middle">
                        @if (user.Role == "Admin")
                        {
                            <span class="badge bg-danger">Admin</span>
                        }
                        else if (user.Role == "Doctor")
                        {
                            <span class="badge bg-info text-dark">Doctor</span>
                        }
                        else if (user.Role == "Staff")
                        {
                            <span class="badge bg-warning text-dark">Staff</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Patient</span>
                        }
                    </td>
                    <td class="align-middle">
                        @if (!string.IsNullOrEmpty(user.Specialization))
                        {
                            <span class="text-primary fw-bold">@user.Specialization</span>
                        }
                        else
                        {
                            <span class="text-muted">-</span>
                        }
                    </td>
                    <td class="align-middle">
                        <div class="d-flex gap-2">

                            @if (user.Role == "Doctor")
                            {
                                <a asp-action="ManageSchedule" asp-route-doctorId="@user.Id" class="btn btn-sm btn-info text-white" title="Manage Shift">
                                    📅 Schedule
                                </a>
                            }

                            @if (user.Role != "Patient")
                            {
                                <a asp-action="Edit" asp-route-id="@user.Id" class="btn btn-sm btn-warning text-dark" title="Edit Profile/Fee">
                                    ✏ Edit
                                </a>
                            }
                            @if (user.Role != "Admin")
                            {
                                <form asp-action="Delete" method="post" onsubmit="return confirm('Fire this employee? This cannot be undone.');">
                                    <input type="hidden" name="id" value="@user.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Fire Employee">❌ Remove</button>
                                </form>
                            }
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <a asp-controller="Account" asp-action="AdminDashboard" class="btn btn-secondary mt-3">Back to Dashboard</a>
</div>