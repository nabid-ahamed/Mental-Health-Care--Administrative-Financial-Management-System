@model IEnumerable<MHC_AFMS.Models.Invoice>

@{
    ViewData["Title"] = "My Bills";
}

<div class="container mt-4">
    <h2 class="text-success">💳 My Bills</h2>
    <hr />

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="row">
        @foreach (var item in Model)
        {
            // CHECK: Are there pending tests?
            bool isBlocked = item.Appointment.AppointmentTests
            .Any(t => t.Status == "Suggested" || t.Status == "Accepted");

            <div class="col-md-4">
                <div class="card mb-3 shadow-sm @(item.Status == "Paid" ? "border-success" : "border-danger")">
                    <div class="card-body">
                        <h5 class="card-title">Invoice #@item.Id</h5>
                        <h2 class="display-6">@item.Amount.ToString("C")</h2>
                        <p class="text-muted">Due: @item.DueDate.ToString("d")</p>

                        @if (item.Status == "Unpaid")
                        {
                            @if (isBlocked)
                            {
                                <button class="btn btn-secondary w-100" disabled>
                                    🔒 Waiting for Lab
                                </button>
                                <div class="text-danger small mt-2 text-center">
                                    Tests pending or incomplete. <br />Check "My Appointments".
                                </div>
                            }
                            else
                            {
                                <a asp-action="Gateway" asp-route-invoiceId="@item.Id" class="btn btn-primary w-100">
                                    Pay Now 💳
                                </a>
                            }
                        }
                        else
                        {
                            <button class="btn btn-success w-100" disabled>✅ Paid</button>
                        }
                    </div>
                </div>
            </div>
        }
    </div>

    <a asp-controller="Account" asp-action="PatientDashboard" class="btn btn-secondary mt-3">Back to Dashboard</a>
</div>