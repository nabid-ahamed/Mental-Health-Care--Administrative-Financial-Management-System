@model MHC_AFMS.Models.ViewModels.AdminFinancialViewModel

@{
    ViewData["Title"] = "Financial Dashboard";
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-primary">📈 Financial Dashboard</h2>
        <div>
            <form method="get" class="d-flex gap-2 align-items-end">
                <div>
                    <label class="small text-muted">Start Date</label>
                    <input type="date" name="startDate" class="form-control form-control-sm" value="@Model.StartDate.ToString("yyyy-MM-dd")" />
                </div>
                <div>
                    <label class="small text-muted">End Date</label>
                    <input type="date" name="endDate" class="form-control form-control-sm" value="@Model.EndDate.ToString("yyyy-MM-dd")" />
                </div>
                <button type="submit" class="btn btn-primary btn-sm">Filter</button>
            </form>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card text-white bg-success shadow-sm">
                <div class="card-body">
                    <h6 class="card-title">Revenue (Selected Period)</h6>
                    <h3>@Model.RevenueTotal.ToString("C")</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-white bg-info shadow-sm">
                <div class="card-body">
                    <h6 class="card-title">Revenue (Today)</h6>
                    <h3>@Model.RevenueToday.ToString("C")</h3>
                    <small>@Model.AppointmentsToday appts / @Model.TestsToday tests</small>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-white bg-warning shadow-sm">
                <div class="card-body">
                    <h6 class="card-title">Pending Payments</h6>
                    <h3>@Model.PendingPayments.ToString("C")</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-white bg-secondary shadow-sm">
                <div class="card-body">
                    <h6 class="card-title">Paid Payments</h6>
                    <h3>@Model.PaidPayments.ToString("C")</h3>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-4 mb-4">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-dark text-white">
                    Income Sources
                </div>
                <div class="card-body">
                    <ul class="list-group list-group-flush">
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            🩺 Consultation Fees
                            <span class="fw-bold text-primary">@Model.TotalConsultationFees.ToString("C")</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            🧪 Lab/Test Fees
                            <span class="fw-bold text-success">@Model.TotalTestFees.ToString("C")</span>
                        </li>
                    </ul>
                    <div class="mt-3 text-center">
                        <small class="text-muted">Total Calculated: @((Model.TotalConsultationFees + Model.TotalTestFees).ToString("C"))</small>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-8 mb-4">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-dark text-white">
                    Top Performing Doctors
                </div>
                <div class="card-body">
                    <table class="table table-striped table-hover">
                        <thead>
                            <tr>
                                <th>Doctor</th>
                                <th>Patients Seen</th>
                                <th>Revenue Generated</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var doc in Model.DoctorStats.Take(5))
                            {
                                <tr>
                                    <td>@doc.DoctorName</td>
                                    <td>@doc.AppointmentCount</td>
                                    <td class="text-success fw-bold">@doc.TotalEarnings.ToString("C")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <div class="card shadow-sm">
                <div class="card-header bg-dark text-white">
                    Lab Test Performance
                </div>
                <div class="card-body">
                    <table class="table table-bordered">
                        <thead>
                            <tr>
                                <th>Test Name</th>
                                <th>Times Performed</th>
                                <th>Total Income</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var test in Model.TestStats)
                            {
                                <tr>
                                    <td>@test.TestName</td>
                                    <td>@test.Count</td>
                                    <td>@test.TotalIncome.ToString("C")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-3 text-end">
        <button onclick="window.print()" class="btn btn-outline-secondary">🖨 Print / Save as PDF</button>
    </div>
</div>