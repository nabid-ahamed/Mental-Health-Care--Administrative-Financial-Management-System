@using Microsoft.AspNetCore.Identity
@using MHC_AFMS.Models

@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<ul class="navbar-nav">
    @if (SignInManager.IsSignedIn(User))
    {
        // 🟢 FETCH FULL NAME
        var user = await UserManager.GetUserAsync(User);
        string displayName = user?.FullName ?? User.Identity?.Name;

        <li class="nav-item">
            <a class="nav-link text-dark fw-bold" asp-controller="Account" asp-action="Profile" title="Manage">
                Hello @displayName!
            </a>
        </li>
        <li class="nav-item">
            <form class="form-inline" asp-controller="Account" asp-action="Logout" method="post">
                <button type="submit" class="nav-link btn btn-link text-danger fw-bold">Logout</button>
            </form>
        </li>
    }
    else
    {
        <li class="nav-item">
            <a class="nav-link text-dark" asp-controller="Account" asp-action="Login">Login</a>
        </li>
        <li class="nav-item">
            <a class="nav-link text-primary fw-bold" asp-controller="Account" asp-action="Register">Register</a>
        </li>
    }
</ul>