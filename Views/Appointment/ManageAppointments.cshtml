@model IEnumerable<MHC_AFMS.Models.Appointment>

@{
    ViewData["Title"] = "Manage Appointments";
}

<div class="container mt-4">
    <h2>📅 Manage All Appointments</h2>
    <p class="text-muted">Review, Approve, or Cancel patient bookings.</p>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover table-striped mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Date</th>
                        <th>Time Slot</th>
                        <th>Patient</th>
                        <th>Doctor</th>
                        <th>Description</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="align-middle">@item.AppointmentDate.ToString("MMM dd, yyyy")</td>

                            <td class="align-middle fw-bold text-nowrap">
                                @DateTime.Today.Add(item.StartTime).ToString("h:mm tt")
                            </td>

                            <td class="align-middle">
                                @if (item.Patient != null)
                                {
                                    <span class="fw-bold">@item.Patient.FullName</span>
                            
                                    <br />
                                    <small class="text-muted">@item.Patient.ContactNumber</small>
                                }
                                else
                                {
                                    <span class="text-danger">Unknown</span>
                                }
                            </td>

                            <td class="align-middle text-primary">
                                Dr. @(item.Doctor?.FullName ?? "Unknown")
                            </td>

                            <td class="align-middle">
                                @if (string.IsNullOrEmpty(item.Description))
                                {
                                    <span class="text-muted small">No description</span>
                                }
                                else
                                {
                                    <span>@item.Description</span>
                                }
                            </td>

                            <td class="align-middle">
                                @if (item.Status == "Pending")
                                {
                                    <span class="badge bg-warning text-dark">Pending</span>
                                }
                                else if (item.Status == "Approved")
                                {
                                    <span class="badge bg-success">Approved</span>
                                }
                                else if (item.Status == "Completed")
                                {
                                    <span class="badge bg-primary">Completed</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Cancelled</span>
                                }
                            </td>

                            <td class="align-middle text-nowrap">
                                @if (item.Status == "Pending")
                                {
                                    <div class="d-flex gap-2">
                                        <form asp-action="Approve" method="post">
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <button type="submit" class="btn btn-sm btn-success">✔ Approve</button>
                                        </form>

                                        <form asp-action="Cancel" method="post" onsubmit="return confirm('Reject this appointment?');">
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger">✖ Reject</button>
                                        </form>
                                    </div>
                                }
                                else if (item.Status == "Approved")
                                {
                                    <form asp-action="Cancel" method="post" onsubmit="return confirm('Cancel this approved appointment?');">
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <button type="submit" class="btn btn-sm btn-secondary">Cancel Booking</button>
                                    </form>
                                }
                                else
                                {
                                    <span class="text-muted small">-</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="mt-3">
        <a asp-controller="Account" asp-action="StaffDashboard" class="btn btn-secondary">Back to Dashboard</a>
    </div>
</div>