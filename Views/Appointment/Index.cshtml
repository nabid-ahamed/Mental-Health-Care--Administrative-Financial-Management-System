@model IEnumerable<MHC_AFMS.Models.ApplicationUser>

@{
    ViewData["Title"] = "Find a Doctor";
}

<div class="container mt-4">
    <div class="text-center mb-5">
        <h1 class="display-5">👨‍⚕️ Find a Specialist</h1>
        <p class="lead text-muted">Book an appointment with our expert doctors.</p>
    </div>

    <div class="row justify-content-center mb-4">
        <div class="col-md-6">
            <form asp-action="Index" method="get" class="d-flex gap-2">
                <input type="text" name="searchString" class="form-control form-control-lg" placeholder="Search by Name or Specialization..." />
                <button type="submit" class="btn btn-lg btn-primary">Search</button>
            </form>
        </div>
    </div>

    <div class="row">
        @if (!Model.Any())
        {
            <div class="col-12 text-center">
                <div class="alert alert-warning">No doctors found matching your search.</div>
            </div>
        }

        @foreach (var doctor in Model)
        {
            <div class="col-md-4 mb-4">
                <div class="card shadow-sm h-100 border-0">
                    <div class="card-body text-center">
                        <div class="mb-3">
                            <div class="bg-light rounded-circle d-inline-flex align-items-center justify-content-center" style="width: 80px; height: 80px;">
                                <span class="fs-1">🩺</span>
                            </div>
                        </div>
                        <h4 class="card-title">@doctor.FullName</h4>
                        <p class="text-primary fw-bold mb-1">@doctor.Specialization</p>
                        <p class="text-muted small">Consultation Fee: @doctor.ConsultationFee.ToString("C")</p>

                        <hr />

                        <a asp-action="Book" asp-route-doctorId="@doctor.Id" class="btn btn-success w-100">
                            📅 Book Appointment
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>